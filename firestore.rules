rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User data validation
    function isValidUser(data) {
      return data.keys().hasAll(['player', 'updatedAt']) &&
             data.player is map &&
             data.updatedAt is string;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users shouldn't be listable
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().updatedAt != existing().updatedAt;
                      
      allow delete: if isOwner(userId);
    }

    // World Players
    function isValidWorldPlayer(data) {
      return data.keys().hasAll(['locationId', 'x', 'y', 'hp', 'maxHp', 'level', 'nickname', 'updatedAt']) &&
             data.locationId is string &&
             data.x is number &&
             data.y is number &&
             data.hp is number &&
             data.maxHp is number &&
             data.level is number &&
             data.nickname is string &&
             data.updatedAt is number;
    }

    match /worldPlayers/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isOwner(userId) && isValidWorldPlayer(incoming());
      allow update: if isSignedIn() && isValidWorldPlayer(incoming()); // Allow PVP damage
      allow delete: if isOwner(userId);
    }
    function isValidRoom(data) {
      return data.host is map &&
             data.host.uid is string &&
             data.host.hp is number &&
             data.status in ['waiting', 'fighting', 'finished'];
    }

    match /rooms/{roomId} {
      function isParticipant() {
        return isSignedIn() && (
          (resource.data.host != null && request.auth.uid == resource.data.host.uid) || 
          (resource.data.opponent != null && request.auth.uid == resource.data.opponent.uid)
        );
      }

      function isHost() {
        return isSignedIn() && resource.data.host != null && request.auth.uid == resource.data.host.uid;
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && 
                    isValidRoom(incoming()) &&
                    incoming().host.uid == request.auth.uid;

      allow update: if isSignedIn() && (
        // Action: Join
        (existing().status == 'waiting' && 
         incoming().status == 'fighting' && 
         incoming().opponent.uid == request.auth.uid) ||
        
        // Action: Activity (Movement, Combat, Finish)
        (isParticipant() && 
         (incoming().status in ['fighting', 'finished'])) ||
         
         // Allow host to cancel/finish
         isHost()
      );

      allow delete: if isSignedIn() && isHost();
    }
  }
}
