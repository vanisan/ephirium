{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and game progress",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "player": {
          "type": "object",
          "properties": {
            "level": { "type": "number" },
            "exp": { "type": "number" },
            "nextLevelExp": { "type": "number" },
            "gold": { "type": "number" },
            "shards": { "type": "number" },
            "potions": { "type": "number" },
            "hp": { "type": "number" },
            "maxHp": { "type": "number" },
            "stats": { "type": "object" },
            "recipes": { "type": "array", "items": { "type": "string" } }
          }
        },
        "inventory": { "type": "array" },
        "equipment": { "type": "object" },
        "currentLocationId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "player"]
    },
    "Room": {
      "title": "Arena Room",
      "description": "A match room for PvP",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["waiting", "fighting", "finished"] },
        "host": { 
          "type": "object",
          "properties": {
            "uid": { "type": "string" },
            "name": { "type": "string" },
            "hp": { "type": "number" },
            "maxHp": { "type": "number" },
            "stats": { "type": "object" },
            "skinColor": { "type": "string" },
            "weaponType": { "type": "string" },
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "opponent": { 
          "type": "object",
          "properties": {
            "uid": { "type": "string" },
            "name": { "type": "string" },
            "hp": { "type": "number" },
            "maxHp": { "type": "number" },
            "stats": { "type": "object" },
            "skinColor": { "type": "string" },
            "weaponType": { "type": "string" },
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "winner": { "type": "string" },
        "lastAction": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "WorldPlayer": {
      "title": "World Player",
      "description": "Public player data for multiplayer sync",
      "type": "object",
      "properties": {
        "locationId": { "type": "string" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "hp": { "type": "number" },
        "maxHp": { "type": "number" },
        "level": { "type": "number" },
        "nickname": { "type": "string" },
        "updatedAt": { "type": "number" }
      }
    },
    "Mob": {
      "title": "World Mob",
      "description": "Shared enemy data",
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "hp": { "type": "number" },
        "maxHp": { "type": "number" },
        "level": { "type": "number" },
        "type": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Main user document containing all game state"
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "PvP match rooms"
    },
    "/worldPlayers/{userId}": {
      "schema": "WorldPlayer",
      "description": "Public player presence"
    },
    "/worldMobs/{locationId}/mobs/{mobId}": {
      "schema": "Mob",
      "description": "Shared mobs mapping"
    }
  }
}
